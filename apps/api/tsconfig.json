{
    "extends":  "../../tsconfig.json",
    "compilerOptions":  {
        "outDir":  "./dist",
        "ignoreDeprecations":  "6.0",
        "baseUrl":  ".",
        "paths":  {
        "@/*":  [
                    "src/*"
                ],
        "@backend/shared/*":  [
                                "../../packages/shared/*"
                            ],
        "@backend/api/*":  [
                                "src/*"
                            ]
        }
        },
        "include":  [
                    "src/**/*"
                ]
}
