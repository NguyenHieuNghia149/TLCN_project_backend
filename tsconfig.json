{
  "compilerOptions": {
    "target": "ES2022",
    "module": "commonjs",
    "lib": ["ES2022"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "removeComments": true,
    "noImplicitAny": true,
    "strictNullChecks": true,
    "strictFunctionTypes": true,
    "noImplicitThis": true,
    "noImplicitReturns": true,
    "noFallthroughCasesInSwitch": true,
    "noUncheckedIndexedAccess": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "allowSyntheticDefaultImports": true,
    "baseUrl": "./",
    "paths": {
      "@backend/shared": ["packages/shared/index.ts"],
      "@backend/shared/db": ["packages/shared/db/index.ts"],
      "@backend/shared/types": ["packages/shared/types/index.ts"],
      "@backend/shared/utils": ["packages/shared/utils/index.ts"],
      "@backend/shared/*": ["packages/shared/*"],
      "@backend/sandbox/*": ["apps/sandbox/src/*"],
      "@backend/worker/*": ["apps/worker/src/*"],
      "@backend/api/*": ["apps/api/src/*"],
      "@backend/database/*": ["packages/database/src/*"],
      "@backend/shared/validations": ["packages/shared/validations/index.ts"],
    }
  },
  "include": [
    "apps/**/*",
    "packages/**/*",
    "config/**/*",
    "scripts/**/*",
    "tests/**/*"
  ],
  "exclude": [
    "node_modules",
    "dist",
    "coverage",
    "scripts/archive/**/*"
  ],
  "ts-node": {
    "require": ["tsconfig-paths/register"]
  }
}