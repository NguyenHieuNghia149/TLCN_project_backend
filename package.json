{
  "name": "backend",
  "version": "1.0.0",
  "main": "index.js",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:api": "npm run dev --workspace=@backend/api",
    "dev:worker": "npm run dev:worker --workspace=@backend/worker",
    "dev:sandbox": "npm run dev:sandbox --workspace=@backend/sandbox",
    "dev:all": "concurrently \"npm run dev:api\" \"npm run dev:worker\" \"npm run dev:sandbox\"",
    "start:all": "ts-node scripts/start-all.ts",
    "test:security": "ts-node scripts/test-security.ts",
    "test:sandbox": "ts-node scripts/test-sandbox.ts",
    "test:debug": "ts-node scripts/test-debug-fibonacci.ts",
    "start:test": "ts-node scripts/start-and-test.ts",
    "build": "tsc -p apps/api/tsconfig.json && tsc -p apps/worker/tsconfig.json && tsc -p apps/sandbox/tsconfig.json",
    "start:api": "npm run start --workspace=@backend/api",
    "start:worker": "npm run start:worker --workspace=@backend/worker",
    "start:sandbox": "npm run start:sandbox --workspace=@backend/sandbox",
    "test": "jest",
    "test:watch": "jest --watch",
    "test:coverage": "jest --coverage",
    "lint": "eslint apps/*/src/**/*.ts packages/*/src/**/*.ts",
    "lint:fix": "eslint apps/*/src/**/*.ts packages/*/src/**/*.ts --fix",
    "format": "prettier --write apps/*/src/**/*.ts packages/*/src/**/*.ts",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:drop": "drizzle-kit drop",
    "db:check": "drizzle-kit check",
    "db:seed": "ts-node scripts/seed.ts",
    "db:studio": "drizzle-kit studio",
    "prepare": "husky install",
    "db:push": "drizzle-kit push",
    "audit:post-drop": "ts-node scripts/migrate/audit-post-drop.ts",
    "check:no-testcase-text-cache-refs": "ts-node scripts/check-no-testcase-text-cache-refs.ts",
    "perf:challenge-detail:baseline": "artillery run tests/performance/challenge_detail_baseline.yml",
    "perf:challenge-detail:load": "artillery run tests/performance/challenge_detail_load_test.yml"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "description": "",
  "dependencies": {
    "axios": "^1.6.0",
    "bcryptjs": "^3.0.2",
    "cloudinary": "^2.8.0",
    "compression": "^1.8.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "date-fns": "^3.3.1",
    "dotenv": "^17.2.2",
    "drizzle-orm": "^0.44.5",
    "drizzle-zod": "^0.8.3",
    "express": "^5.1.0",
    "express-rate-limit": "^8.1.0",
    "express-validator": "^7.2.1",
    "google-auth-library": "^10.5.0",
    "helmet": "^8.1.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "mammoth": "^1.11.0",
    "morgan": "^1.10.1",
    "multer": "^1.4.5-lts.1",
    "nodemailer": "^7.0.6",
    "nodemon": "^3.1.10",
    "pg": "^8.16.3",
    "socket.io": "^4.7.0",
    "ts-node": "^10.9.2",
    "typescript": "^5.9.2",
    "uuid": "^9.0.0",
    "winston": "^3.17.0",
    "yaml": "^2.8.2",
    "zod": "^4.1.11"
  },
  "devDependencies": {
    "@commitlint/cli": "^19.8.1",
    "@commitlint/config-conventional": "^19.8.1",
    "@types/bcryptjs": "^2.4.6",
    "@types/compression": "^1.8.1",
    "@types/cookie-parser": "^1.4.9",
    "@types/cors": "^2.8.19",
    "@types/express": "^5.0.3",
    "@types/helmet": "^0.0.48",
    "@types/jest": "^30.0.0",
    "@types/jsonwebtoken": "^9.0.10",
    "@types/morgan": "^1.9.10",
    "@types/multer": "^2.0.0",
    "@types/node": "^24.5.2",
    "@types/nodemailer": "^7.0.1",
    "@types/pg": "^8.15.5",
    "@types/redis": "^4.0.10",
    "@types/supertest": "^6.0.3",
    "@types/uuid": "^9.0.0",
    "@types/yaml": "^1.9.6",
    "@typescript-eslint/eslint-plugin": "^8.44.0",
    "@typescript-eslint/parser": "^8.44.0",
    "artillery": "^2.0.30",
    "concurrently": "^9.2.1",
    "cross-env": "^10.0.0",
    "drizzle-kit": "^0.31.4",
    "eslint": "^9.36.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.4",
    "husky": "^9.1.7",
    "jest": "^30.1.3",
    "jscpd": "^4.0.8",
    "lint-staged": "^16.1.6",
    "prettier": "^3.6.2",
    "rimraf": "^6.0.1",
    "supertest": "^7.1.4",
    "ts-jest": "^29.4.4",
    "ts-node": "^10.9.2",
    "tsconfig-paths": "^4.2.0"
  }
}